            "isProd": "[equals(parameters('environment'), 'prod')]"
          },
          "resources": [
            {
              "type": "Microsoft.Search/searchServices",
              "apiVersion": "2023-11-01",
              "name": "[variables('searchServiceName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "[if(variables('isProd'), 'basic', 'free')]"
              },
              "identity": "[if(variables('isProd'), createObject('type', 'SystemAssigned'), null())]",
              "properties": {
                "replicaCount": 1,
                "partitionCount": 1,
                "hostingMode": "default",
                "publicNetworkAccess": "enabled",
                "authOptions": "[if(variables('isProd'), createObject('aadOrApiKey', createObject('aadAuthFailureMode', 'http403')), null())]",
                "semanticSearch": "disabled"
              },
              "tags": {
                "project": "bankretain",
                "environment": "[parameters('environment')]",
                "layer": "ai",
                "purpose": "customer-profile-index"
              }
            }
          ],
          "outputs": {
            "searchServiceName": {
              "type": "string",
              "value": "[variables('searchServiceName')]"

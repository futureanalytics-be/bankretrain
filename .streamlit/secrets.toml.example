# ── BankRetain Dashboard — Secrets Template ───────────────────────────────────
#
# Copy this file to .streamlit/secrets.toml and fill in your values for local dev.
# On Streamlit Community Cloud, paste each key-value pair into
# App settings → Secrets (do NOT commit secrets.toml).
#
# Azure service principal setup:
#   1. az ad sp create-for-rbac --name "bankretain-dashboard-sp" \
#        --role Reader --scopes /subscriptions/<subscription-id>
#   2. In Azure SQL (Azure Data Studio, Entra auth):
#        CREATE USER [bankretain-dashboard-sp] FROM EXTERNAL PROVIDER;
#        ALTER ROLE db_datareader ADD MEMBER [bankretain-dashboard-sp];
#   3. Grant AML Reader role on the workspace in the Azure portal.
# ─────────────────────────────────────────────────────────────────────────────

# Azure SQL
BANKRETAIN_SQL_SERVER = "your-server.database.windows.net"
BANKRETAIN_SQL_DB     = "bankretaindb"

# Azure subscription / AML
AZURE_SUBSCRIPTION_ID = "your-subscription-id"
AML_WORKSPACE_NAME    = "your-aml-workspace-name"
ML_RESOURCE_GROUP     = "bankretain-ml-rg"

# Service principal (DefaultAzureCredential picks these up via EnvironmentCredential)
AZURE_CLIENT_ID     = "your-sp-client-id"
AZURE_CLIENT_SECRET = "your-sp-client-secret"
AZURE_TENANT_ID     = "your-tenant-id"
